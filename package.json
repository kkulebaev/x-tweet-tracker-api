{
  "name": "x-tweet-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hourly tracker for new posts from a list of X accounts.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "cron": "node dist/cron.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "prisma": "^6.19.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  }
}
