generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id         String   @id @default(uuid())
  xUsername  String   @unique @map("x_username")
  xUserId    String?  @unique @map("x_user_id")
  sinceId    String?  @map("since_id")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tweets Tweet[]

  @@map("accounts")
}

model Tweet {
  tweetId   String   @id @map("tweet_id")
  accountId String   @map("account_id")
  createdAt DateTime @map("created_at")
  text      String
  url       String
  raw       Json?
  fetchedAt DateTime @default(now()) @map("fetched_at")

  // For Telegram forwarder queue
  claimedAt DateTime? @map("claimed_at")
  sentAt    DateTime? @map("sent_to_telegram_at")

  account Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  media   TweetMedia[]

  @@index([accountId, createdAt])
  @@index([sentAt, createdAt])
  @@map("tweets")
}

model TweetMedia {
  id       String @id @default(cuid())
  tweetId  String @map("tweet_id")
  url      String
  type     String
  position Int

  tweet Tweet @relation(fields: [tweetId], references: [tweetId], onDelete: Cascade)

  @@unique([tweetId, url])
  @@unique([tweetId, position])
  @@index([tweetId, position])
  @@map("tweet_media")
}
